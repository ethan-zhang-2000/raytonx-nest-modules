{
  "name": "@raytonx/example-app",
  "version": "0.0.0",
  "private": true,
  "description": "Independent NestJS example application for RaytonX Nest packages.",
  "license": "MIT",
  "type": "commonjs",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test:e2e": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsx": "^4.20.6",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
