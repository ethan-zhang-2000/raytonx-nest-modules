{
  "name": "@raytonx/example-app",
  "version": "0.0.0",
  "private": true,
  "description": "Independent NestJS example application for RaytonX Nest packages.",
  "license": "MIT",
  "type": "commonjs",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm build && concurrently -k -n tsc,node -c blue,green \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "start": "node dist/main.js",
    "test:e2e": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.1",
    "@raytonx/config": "^0.2.0",
    "@raytonx/nest-logger": "^0.1.0",
    "@raytonx/nest-redis": "^0.2.1",
    "@raytonx/nest-scheduler": "^0.2.2",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "concurrently": "^9.2.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
